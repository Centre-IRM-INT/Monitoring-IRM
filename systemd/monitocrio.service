[Unit]
Description=Monitocrio FastAPI Server
After=network.target

[Service]
User=monitocrio
WorkingDirectory=/home/monitocrio/Documents/Test-com
ExecStart=/home/monitocrio/Documents/Test-com/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=SUPABASE_URL=...
Environment=SUPABASE_KEY=...

[Install]
WantedBy=multi-user.target